# ─── Database ──────────────────────────────────────────────
# PostgreSQL connection string from Supabase
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:6543/postgres?pgbouncer=true"
# Direct connection (bypasses PgBouncer) for migrations
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# ─── Cache ─────────────────────────────────────────────────
# Upstash Redis REST URL and Token (from Upstash Console → REST API)
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Auth (NextAuth.js) ────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# ─── Instagram / Meta Graph API ────────────────────────────
# 1. Create an app at https://developers.facebook.com
# 2. Add Instagram Testers in App Dashboard → Roles → Instagram Testers
# 3. Get App ID & App Secret from App Dashboard → Settings → Basic
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
# 4. Generate a long-lived Page Access Token via Graph API Explorer
META_APP_ACCESS_TOKEN="your-meta-app-access-token"

# ─── Cron Security (optional but recommended) ──────────────
# Used to authenticate cron job requests from Vercel
CRON_SECRET="your-cron-secret"
