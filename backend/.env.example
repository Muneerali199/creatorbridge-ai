# ─── Database (Neon Free Tier) ──────────────────────────────
# 1. Go to https://neon.tech → New project
# 2. Copy connection string from Project Dashboard → Connection Details
# 3. Use pooled connection (ends with -pooler) for serverless
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb"
# Direct connection for running migrations
DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb"

# ─── Cache (Upstash Redis Free Tier) ───────────────────────
# 1. Go to https://upstash.com → Create Redis database
# 2. Copy REST URL and REST Token from the console
UPSTASH_REDIS_REST_URL="https://[your-region]-[your-id].upstash.io"
UPSTASH_REDIS_REST_TOKEN="[your-upstash-redis-token]"

# ─── Auth (NextAuth.js) ────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="[generate-with: openssl rand -base64 32]"

# ─── Instagram (RapidAPI Scraper) ──────────────────────────
# 1. Go to https://rapidapi.com → Subscribe to "Instagram Scraper Stable API"
# 2. Copy your API key from the "Code Snippets" → "X-RapidAPI-Key" header
RAPIDAPI_KEY="your-rapidapi-key-here"
RAPIDAPI_HOST="instagram-scraper-stable-api.p.rapidapi.com"

# ─── Cron Security (optional) ──────────────────────────────
# Add this as a header check inside cron route if desired
CRON_SECRET="[your-cron-secret]"
